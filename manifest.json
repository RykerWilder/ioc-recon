{
  "manifest_version": 3,
  "name": "IOC Recon",
  "version": "1.0.0",
  "description": "Quick analysis of a selected IOC (IP or URL/domain)",
  "permissions": ["contextMenus", "scripting", "storage", "activeTab"],
  "host_permissions": [
    "https://rdap.org/*",
    "https://dns.google/*",
    "https://api.blocklist.de/*",
    "https://get.geojs.io/*",
    "https://urlscan.io/*",
    "https://check.torproject.org/*",
    "https://ipinfo.io/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "IOC Recon"
  }
}